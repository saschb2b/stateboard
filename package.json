{
  "name": "stateboard",
  "version": "0.1.0",
  "private": true,
  "description": "Status reporting for visual products. Show, don't tell.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:pages": "node scripts/pages-prebuild.mjs && STATEBOARD_PAGES=1 next build",
    "migrate": "node scripts/migrate.mjs"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "better-auth": "^1.6.9",
    "fumadocs-core": "^16.8.7",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "^16.8.7",
    "nanoid": "^5.1.11",
    "next": "16.1.6",
    "pg": "^8.13.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.13",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.20.0"
}
