# Copy this file to .env and adjust for your local setup.
#
# The defaults below work out-of-the-box with the bundled docker-compose
# stack — `docker compose up -d`, then `pnpm migrate && pnpm dev`.

# ---- Database --------------------------------------------------------------
# Postgres connection string. Schema is managed via `pnpm migrate`.
DATABASE_URL=postgres://stateboard:stateboard@localhost:5432/stateboard

# ---- Auth (Better Auth + Keycloak) -----------------------------------------
# Public URL the app reaches itself at. Must match Keycloak's
# "Valid redirect URIs" (StateBoard registers /api/auth/callback/keycloak).
STATEBOARD_BASE_URL=http://localhost:3000

# Random secret used to sign session cookies. Generate fresh:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-please-use-openssl-rand

# Keycloak issuer URL (realm URL). The bundled docker-compose ships a
# "stateboard" realm.
KEYCLOAK_ISSUER=http://localhost:8080/realms/stateboard
KEYCLOAK_CLIENT_ID=stateboard
KEYCLOAK_CLIENT_SECRET=stateboard-dev-secret

# Optional: comma-separated email-domain allowlist. Empty = any signed-in
# Keycloak user (subject to whatever the realm enforces).
# STATEBOARD_ALLOWED_EMAIL_DOMAINS=acme.com,acme.de

# Default role for newly-signed-in users (after the first user, who
# always becomes owner). One of: owner | editor | viewer
STATEBOARD_DEFAULT_ROLE=editor

# ---- Storage ---------------------------------------------------------------
# Where uploaded screenshots live on disk. Defaults to ./data under the
# repo root if unset.
# STATEBOARD_DATA_DIR=/var/lib/stateboard
